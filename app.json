{
  "expo": {
    "name": "얼타지마",
    "slug": "ultagima",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/stage0.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icons/stage0.png",
      "resizeMode": "contain",
      "backgroundColor": "#ff9500"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ultagima.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "UV 지수를 정확히 측정하기 위해 위치 정보가 필요합니다."
      }
    },
    "android": {
      "package": "com.ultagima.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/stage0.png",
        "backgroundColor": "#ff9500"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/stage0.png",
          "color": "#ff9500",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "UV 지수를 정확히 측정하기 위해 위치 정보가 필요합니다."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e6e75105-a0eb-4cab-9243-ef881cce3b76"
      }
    },
    "owner": "taehyeon_yee"
  }
}
